# Environment variables for docker-compose
ENVIRONMENT={{ environment }}
DOCKER_REGISTRY={{ docker_registry }}
CONTAINER_TRELLIS_IMAGE={{ container_trellis_image }}
CONTAINER_MESHROOM_IMAGE={{ container_meshroom_image }}
CUDA_VISIBLE_DEVICES={{ cuda_visible_devices }}
DOCKER_MEMORY_LIMIT={{ docker_memory_limit }}
DOCKER_CPUS_LIMIT={{ docker_cpus_limit }}
DOCKER_RESTART_POLICY={{ docker_restart_policy }}
INPUT_VOLUME={{ data_volumes.input }}
OUTPUT_VOLUME={{ data_volumes.output }}
LOGS_VOLUME={{ data_volumes.logs }}
MODELS_CACHE_VOLUME={{ data_volumes.models_cache }}
