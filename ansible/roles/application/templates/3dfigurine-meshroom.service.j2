[Unit]
Description=3D Figurine Lab - Meshroom Engine
After=docker.service
Requires=docker.service
PartOf=3dfigurine.target

[Service]
Type=simple
Restart={{ docker_restart_policy }}
RestartSec=10
User=azureuser
WorkingDirectory=/opt/3dfigurine

Environment="HOST_UID=1000"
Environment="HOST_GID=1000"
Environment="DOCKER_HOST=unix:///var/run/docker.sock"

ExecStartPre=/usr/bin/docker-compose pull 3dfigurine-meshroom
ExecStart=/usr/bin/docker-compose up 3dfigurine-meshroom
ExecStop=/usr/bin/docker-compose down 3dfigurine-meshroom

StandardOutput=journal
StandardError=journal
SyslogIdentifier=3dfigurine-meshroom

TimeoutStartSec=0
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
