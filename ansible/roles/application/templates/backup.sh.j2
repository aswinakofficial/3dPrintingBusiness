#!/bin/bash
# Backup script for 3D Figurine Lab

set -e

BACKUP_DIR="/opt/3dfigurine/backups"
RETENTION_DAYS={{ backup_retention_days }}
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Create backup directory
mkdir -p "$BACKUP_DIR"

echo "[$(date)] Starting 3D Figurine Lab backup..."

# Backup output data
echo "Backing up output data..."
tar -czf "$BACKUP_DIR/output_$TIMESTAMP.tar.gz" {{ data_volumes.output }}/ || echo "Warning: Output backup failed"

# Backup logs
echo "Backing up logs..."
tar -czf "$BACKUP_DIR/logs_$TIMESTAMP.tar.gz" {{ data_volumes.logs }}/ || echo "Warning: Logs backup failed"

# Backup docker-compose and configuration
echo "Backing up configuration..."
tar -czf "$BACKUP_DIR/config_$TIMESTAMP.tar.gz" /opt/3dfigurine/*.yml /opt/3dfigurine/.env* || echo "Warning: Config backup failed"

# Cleanup old backups
echo "Cleaning up old backups..."
find "$BACKUP_DIR" -type f -name "*.tar.gz" -mtime +$RETENTION_DAYS -delete

echo "[$(date)] Backup complete"
