#!/bin/bash
# GPU monitoring script for 3D Figurine Lab

echo "=== GPU Status ($(date)) ==="
echo ""

if command -v nvidia-smi &> /dev/null; then
    nvidia-smi --query-gpu=index,name,driver_version,vbios_version --format=csv,noheader
    echo ""
    
    echo "GPU Memory Usage:"
    nvidia-smi --query-gpu=index,memory.total,memory.used,memory.free --format=csv,noheader | \
    awk -F',' '{print "  GPU " $1 ": " $3 " / " $2 " (Free: " $4 ")"}'
    echo ""
    
    echo "GPU Utilization:"
    nvidia-smi --query-gpu=index,utilization.gpu,utilization.memory --format=csv,noheader | \
    awk -F',' '{print "  GPU " $1 ": " $2 "% GPU, " $3 "% Memory"}'
    echo ""
    
    echo "GPU Temperature:"
    nvidia-smi --query-gpu=index,temperature.gpu --format=csv,noheader | \
    awk -F',' '{print "  GPU " $1 ": " $2 "°C"}'
    echo ""
    
    echo "Running Compute Processes:"
    nvidia-smi pmon -c 1 | grep -v "C   SM   MEM   ENC   DEC   ENC%   DEC%"
else
    echo "NVIDIA GPU not available"
fi
